{
  "name": "chatline",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:mobile": "npm run start --workspace @chatline/mobile",
    "dev:api": "npm run start:dev --workspace @chatline/api",
    "typecheck:mobile": "npm run typecheck --workspace @chatline/mobile",
    "build:api": "npm run build --workspace @chatline/api",
    "test:api": "npm run test --workspace @chatline/api"
  }
}